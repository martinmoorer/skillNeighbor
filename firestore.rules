rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt'])
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 255
        && data.bio is string && data.bio.size() <= 1000
        && (data.skillsOffered is list || !data.keys().contains('skillsOffered'))
        && (data.skillsWanted is list || !data.keys().contains('skillsWanted'));
    }

    function isValidSkillPost(data) {
      return data.keys().hasAll(['authorId', 'type', 'title', 'description', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.type in ['offer', 'request']
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.createdAt == request.time;
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'skillPostId', 'status', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.senderId != data.receiverId
        && data.status in ['pending', 'accepted', 'rejected', 'completed']
        && data.createdAt == request.time;
    }

    // Collection Rules

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'skillsOffered', 'skillsWanted', 'photoURL', 'location']);
    }

    match /skillPosts/{postId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isVerified() && isValidSkillPost(incoming()) && isValidId(postId);
      allow update: if isOwner(existing().authorId) && isValidSkillPost(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'active', 'category', 'locationHint']);
      allow delete: if isOwner(existing().authorId);
    }

    match /trades/{tradeId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isVerified() && isValidTrade(incoming()) && isValidId(tradeId);
      allow update: if isSignedIn() 
        && (
          // Sender can cancel
          (request.auth.uid == existing().senderId && incoming().status == 'completed' && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
          ||
          // Receiver can accept/reject
          (request.auth.uid == existing().receiverId && incoming().status in ['accepted', 'rejected', 'completed'] && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        );
    }
  }
}
